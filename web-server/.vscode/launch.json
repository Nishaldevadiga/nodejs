{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web Server: Debug",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/app.js",
      "runtimeArgs": ["--inspect-brk"],
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
